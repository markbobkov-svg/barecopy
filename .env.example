# Set these as Environment Variables in the Vercel project (Production + Preview),
# and copy to a local ".env" for `vercel dev`. Never commit real values.

# ── Email relay (SMTP) ──────────────────────────────────────────────────────
# Used by BOTH the contact form (/api/contact) and the Pro sign-in magic link
# (/api/login). One relay, two purposes.
SMTP_HOST=smtp.your-host.com
SMTP_PORT=587                 # 587 = STARTTLS, 465 = implicit TLS
SMTP_SECURE=false             # "true" only for port 465
SMTP_USER=your-mailbox@your-domain.com
SMTP_PASS=your-smtp-password  # use an app password if your host offers one

# Where contact messages are delivered (defaults to support@barecopy.com):
CONTACT_TO=support@barecopy.com
# From: header (used for BOTH contact + sign-in emails). Many hosts require this
# to equal SMTP_USER; leave unset to default to it.
CONTACT_FROM=your-mailbox@your-domain.com

# ── Pro payments & entitlement (Polar) ──────────────────────────────────────
# Entitlement is server-side: /api/checkout creates a Polar checkout, /api/confirm
# verifies the payment and sets a signed session cookie, /api/me reads it back.
# There is NO license key — a returning user signs in by email (magic link).

# Polar organization access token (Polar → Settings → Developers → New Token).
# Server-side ONLY — never exposed to the browser. Keep it secret.
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxxxxxxxxxxxxxxxxxx
# The Barecopy Pro product's ID (Polar → Products → Barecopy Pro → copy the ID).
POLAR_PRODUCT_ID=00000000-0000-0000-0000-000000000000
# Secret used to sign the session cookie (HS256). Generate a long random value,
# e.g.  openssl rand -hex 32  — rotating it signs everyone out.
JWT_SECRET=change-me-to-a-long-random-string
# Canonical site origin — feeds the checkout success URL and the magic-link URL.
# Deliberately NOT read from request headers (host-header-injection guard).
APP_ORIGIN=https://www.barecopy.com

# Optional: Vercel KV / Upstash REST for cross-instance rate limiting on
# /api/login + /api/checkout. Without it, a weaker per-instance limiter is used.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
