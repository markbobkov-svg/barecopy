# Contact form (/api/contact) — SMTP relay settings.
# Set these as Environment Variables in the Vercel project (Production + Preview),
# and copy to a local ".env" for `vercel dev`. Never commit real values.

SMTP_HOST=smtp.your-host.com
SMTP_PORT=587                 # 587 = STARTTLS, 465 = implicit TLS
SMTP_SECURE=false             # "true" only for port 465
SMTP_USER=your-mailbox@your-domain.com
SMTP_PASS=your-smtp-password  # use an app password if your host offers one

# Where contact messages are delivered (defaults to support@barecopy.com):
CONTACT_TO=support@barecopy.com
# From: header. Many hosts require this to equal SMTP_USER; leave unset to default to it.
CONTACT_FROM=your-mailbox@your-domain.com
